# Project profile for P2949/stutter.
# This file is automatically sourced when TARGET_REPO basename is "stutter".
PROJECT_PROFILE_NAME="stutter"
PROJECT_REVIEW_ADDENDUM="$PIPELINE_DIR/prompts/stutter-review-addendum.md"

# stutter is systems code: keep patches small and force a second opinion on risky diffs.
MAX_CHANGED_FILES=5
MAX_CHANGED_SOURCE_FILES=5
MAX_DIFF_BYTES_FOR_APPROVAL=120000
ENFORCE_SECOND_OPINION_ON_RISK=1

# Use the explicit nightly toolchain because stutter builds an Aya/eBPF workspace.
VERIFY_USE_RUSTUP_TOOLCHAIN=1
VERIFY_RUSTUP_TOOLCHAIN="nightly"
VERIFY_FMT_CMD="cargo fmt --check"
VERIFY_FMT_RESCUE_CMD="cargo fmt"
VERIFY_BUILD_CMD="cargo build"
VERIFY_CLIPPY_CMD="cargo clippy --all-targets -- -D warnings"
VERIFY_TEST_CMD="cargo test"
VERIFY_WORKSPACE_TEST_CMD="cargo test --workspace"

# stutter-specific context packs are used before generic source packing.
CONTEXT_PACK_EBPF="stutter-common/src/lib.rs stutter-ebpf/src/main.rs stutter/src/ebpf_loader.rs stutter/src/metrics.rs stutter/build.rs stutter-ebpf/Cargo.toml"
CONTEXT_PACK_TRACKING="stutter/src/main.rs stutter/src/process_tree.rs stutter/src/cli.rs"
CONTEXT_PACK_REPORT="stutter/src/recorder.rs stutter/src/report.rs stutter/src/metrics.rs"
CONTEXT_PACK_AFFINITY="stutter/src/affinity.rs stutter/src/profiles.rs stutter/src/process_tree.rs"
CONTEXT_PACK_TUNE="stutter/src/main.rs stutter/src/scorer.rs stutter/src/profiles.rs stutter/src/recorder.rs"

# Always consider these high-risk for shadow finder / second opinion.
HIGH_SEVERITY_KEYWORDS="$HIGH_SEVERITY_KEYWORDS,WAKEUP_DATA,TARGET_PIDS,DROP_COUNTERS,BLOCK_START,PREV_FAULTS,TARGET_IRQS,RLIMIT_MEMLOCK,memlock,tracepoint,AffinityRecord,restore,tune,cgroup,MangoHud,block I/O"
RISK_DIFF_REGEX='^[+-].*(unsafe|repr\(C\)|aya|ebpf|tracepoint|WAKEUP_DATA|TARGET_PIDS|DROP_|BLOCK_START|PREV_FAULTS|TARGET_IRQS|RLIMIT_MEMLOCK|memlock|sched_|sched_setaffinity|AffinityRecord|restore|schema_version|cgroup|MangoHud|block_io|fault|irq|cpu_frequency)'
CONTEXT_PACK_CLI="stutter/src/cli.rs stutter/src/main.rs stutter/src/report.rs stutter/src/regression_tests.rs"

HIGH_SEVERITY_KEYWORDS="$HIGH_SEVERITY_KEYWORDS,CLI,argument,validation,contradictory,watch-process,ReportArgs,MonitorArgs,RecordArgs,parse_app_command,print_report,write_html_report,print_diff_report"