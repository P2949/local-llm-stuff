# Maximum patch/review loops before human escalation.
MAX_PATCH_ITERATIONS=3

# Supported task modes:
# - review: read-only issue discovery; stops after accepted-items extraction.
# - fix: accepted concrete bugs are patched by the local editor model.
# - feature: accepted feature implementation items are patched by the local editor model.
DEFAULT_TASK_MODE="fix"

# Keywords that trigger shadow finder or second opinion.
HIGH_SEVERITY_KEYWORDS="unsafe,pub fn,pub struct,pub enum,pub trait,serialize,deserialize,unwrap,expect,transmute,FFI,raw pointer,file I/O,state invariant,public API,eBPF,ABI,affinity,restore,cgroup,tracepoint"

# Aider settings.
AIDER_BIN="aider"
AIDER_MAP_TOKENS=512
AIDER_EDIT_FORMAT="diff"
AIDER_EXTRA_ARGS=""
AIDER_TIMEOUT_SECONDS=3600
# Used only when the installed Aider does not support --message-file.
# Keep this conservative to avoid argv limits and prompt leakage in process listings.
AIDER_MAX_MESSAGE_ARG_BYTES=24000

# Editor model names as Aider sees them through the OpenAI-compatible endpoint.
# POLICY: only local OpenAI-compatible models may be used for editing.
EDITOR_MODEL="openai/qwen3-coder-30b-a3b"
EDITOR_CHALLENGER_MODEL="openai/devstral-small-2507"
ACTIVE_EDITOR_MODEL="$EDITOR_MODEL"
LOCAL_EDITOR_MODEL_ALLOWLIST="openai/qwen3-coder-30b-a3b openai/devstral-small-2507"
LOCAL_EDITOR_API_BASE_PREFIX="http://127.0.0.1:"

# Context packing limits. Defaults are intentionally conservative for 8K
# llama-server contexts. Put machine/task-specific larger values in
# config/pipeline.local.env.
CONTEXT_MAX_SOURCE_FILES=12
CONTEXT_MAX_SOURCE_BYTES=16000
CONTEXT_MAX_DIFF_BYTES=60000
CONTEXT_MAX_COMMAND_LINES=120
CONTEXT_MAX_COMMAND_BYTES=4000
CONTEXT_MAX_REPO_MAP_BYTES=8000

# Enforcement: 16-rule operating model.
# These are intentionally default-on. Override only in pipeline.local.env when
# you explicitly want a weaker experimental run.
ENFORCE_16_STEP_POLICY=1
ENFORCE_LOCAL_EDITOR_ONLY=1
ENFORCE_NO_AGENT_COMMITS=1
ENFORCE_REVIEW_ONLY_MODE=1
ENFORCE_ALLOWED_FILES=1
ENFORCE_PATCH_SIZE_LIMIT=1
ENFORCE_FEATURE_TEST_CHANGE=1
ENFORCE_HARD_VERIFY_GATES=1
ENFORCE_SECOND_OPINION_ON_RISK=1
ENFORCE_HUMAN_MERGE_ONLY=1
ENFORCE_PROJECT_PROFILE=1

# Hard verification gates. The verifier runs these after every editor pass.
# Generic projects use their repository default toolchain. Project profiles can
# opt in to rustup, e.g. stutter uses nightly for Aya/eBPF.
VERIFY_USE_RUSTUP_TOOLCHAIN=0
VERIFY_RUSTUP_TOOLCHAIN="nightly"
VERIFY_FMT_CMD="cargo fmt --check"
VERIFY_FMT_RESCUE_CMD="cargo fmt"
VERIFY_BUILD_CMD="cargo build"
VERIFY_CLIPPY_CMD="cargo clippy --all-targets -- -D warnings"
VERIFY_TEST_CMD="cargo test"
VERIFY_WORKSPACE_TEST_CMD="cargo test --workspace"

# Optional quality tools. Missing tools are recorded as SKIP. If present and
# set to hard, non-zero output blocks the patch.
OPTIONAL_QUALITY_TOOLS="audit deny machete llvm_cov mutants"
CARGO_AUDIT_MODE="warn"      # off | warn | hard
CARGO_DENY_MODE="warn"       # off | warn | hard
CARGO_MACHETE_MODE="warn"    # off | warn | hard
CARGO_LLVM_COV_MODE="off"    # off | warn | hard
CARGO_MUTANTS_MODE="off"     # off | warn | hard

# Patch-size and feature safety limits.
MAX_CHANGED_FILES=5
MAX_CHANGED_SOURCE_FILES=5
MAX_DIFF_BYTES_FOR_APPROVAL=120000
FEATURE_REQUIRE_TEST_CHANGES=1
TEST_CHANGE_PATTERNS="tests/|src/.+test|regression_tests|#\[test\]|mod tests"

# Project-profile support. If config/projects/<repo-basename>.env exists,
# new-run.sh records and pipeline.sh sources it for stricter project rules.
PROJECT_PROFILE_DIR="$PIPELINE_DIR/config/projects"
PROJECT_REVIEW_ADDENDUM_DIR="$PIPELINE_DIR/prompts"

# Risk patterns that force a second opinion even if the primary review approves.
RISK_DIFF_REGEX='^[+-].*(unsafe|pub fn|pub struct|pub enum|pub trait|serialize|deserialize|file I/O|state invariant|eBPF|tracepoint|sched_setaffinity|raw pointer|repr\(C\)|schema_version)'

# Optional local overrides. This file is gitignored and is the right place for
# larger context budgets, alternative editor settings, or local risk triggers.
if [ -n "${PIPELINE_DIR:-}" ] && [ -f "$PIPELINE_DIR/config/pipeline.local.env" ]; then
  # shellcheck source=/dev/null
  source "$PIPELINE_DIR/config/pipeline.local.env"
fi
