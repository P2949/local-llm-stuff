# Model paths. Adjust these if your local filenames differ.
: "${QWEN27B_MODEL:=$HOME/Desktop/llm/models/qwen3.6-27b/Qwen3.6-27B-Q3_K_M.gguf}"
: "${QWEN35B_MODEL:=$HOME/Desktop/llm/models/qwen3.6-35b-a3b/Qwen3.6-35B-A3B-UD-Q3_K_M.gguf}"
: "${QWEN35B_FALLBACK_MODEL:=$HOME/Desktop/llm/models/qwen3.6-35b-a3b/Qwen3.6-35B-A3B-UD-Q3_K_S.gguf}"
: "${QWEN_CODER_MODEL:=$HOME/Desktop/llm/models/Qwen3-Coder-Next/Qwen3-Coder-30B-A3B-Instruct-Q3_K_M.gguf}"
: "${GEMMA_MODEL:=$HOME/Desktop/llm/models/gemma-4-26b-a4b/gemma-4-26B-A4B-it-UD-Q3_K_M.gguf}"
: "${DEVSTRAL_MODEL:=$HOME/Desktop/llm/models/devstral-small-2507/mistralai_Devstral-Small-2507-Q4_K_M.gguf}"

# Ports.
: "${QWEN27B_PORT:=8081}"
: "${QWEN_CODER_PORT:=8082}"
: "${QWEN35B_PORT:=8083}"
: "${GEMMA_PORT:=8084}"
: "${DEVSTRAL_PORT:=8085}"

# llama-server binary.
# Your llama.cpp checkout lives under ~/Desktop/llm/src/llama.cpp.
: "${LLAMA_SERVER:=$HOME/Desktop/llm/src/llama.cpp/build/bin/llama-server}"

# Server context defaults.
# Keep read-only review/planning models bounded even if you experiment with a
# huge editor context in config/models.local.env. Large contexts made finder and
# challenge prompts slow and encouraged repeated reasoning loops.
: "${DEFAULT_CTX:=65536}"
: "${QWEN27B_CTX:=$DEFAULT_CTX}"
: "${QWEN35B_CTX:=$DEFAULT_CTX}"
: "${GEMMA_CTX:=$DEFAULT_CTX}"
: "${QWEN_CODER_CTX:=65536}"
: "${DEVSTRAL_CTX:=65536}"

# Chat completion output caps. A 1-3k token budget is enough for finder,
# challenge, patch-writer, and candidate review reports; larger output usually
# means the model is looping or leaking hidden reasoning.
: "${MODEL_MAX_TOKENS_DEFAULT:=4096}"
: "${QWEN27B_MAX_TOKENS:=4096}"
: "${QWEN35B_MAX_TOKENS:=4096}"
: "${GEMMA_MAX_TOKENS:=4096}"
: "${QWEN_CODER_MAX_TOKENS:=4096}"
: "${DEVSTRAL_MAX_TOKENS:=4096}"

# Hard output byte caps after extraction from the model response. These catch
# repeated markdown even if max_tokens is overridden locally.
: "${MODEL_OUTPUT_MAX_BYTES_DEFAULT:=48000}"
: "${QWEN27B_OUTPUT_MAX_BYTES:=$MODEL_OUTPUT_MAX_BYTES_DEFAULT}"
: "${QWEN35B_OUTPUT_MAX_BYTES:=$MODEL_OUTPUT_MAX_BYTES_DEFAULT}"
: "${GEMMA_OUTPUT_MAX_BYTES:=$MODEL_OUTPUT_MAX_BYTES_DEFAULT}"
: "${QWEN_CODER_OUTPUT_MAX_BYTES:=48000}"
: "${DEVSTRAL_OUTPUT_MAX_BYTES:=48000}"

# Cold model loads can take longer than 90s on some GGUFs/builds.
: "${MODEL_START_TIMEOUT_SECONDS:=420}"
: "${MODEL_ASK_TIMEOUT_SECONDS:=900}"

# Common llama-server flags.
# Keep reasoning disabled by default; thinking/reasoning leakage was a real
# failure mode in local tests and can consume tens of thousands of tokens.
: "${LLAMA_FLAGS:=-ngl 999 -fa on -np 1 --reasoning off -ctk q8_0 -ctv q8_0}"

# Extra llama-server device/runtime arguments.
# Use this to force a specific llama.cpp device after checking `llama-server --list-devices`.
# Examples, depending on llama.cpp build/version:
#   LLAMA_EXTRA_ARGS="--device Vulkan1"
#   LLAMA_EXTRA_ARGS="--device 1"
: "${LLAMA_EXTRA_ARGS:=}"

# Optional environment prefix for AMD Vulkan setups.
# IMPORTANT: this file preserves an externally supplied MODEL_ENV_PREFIX.
# That means this works:
#   MODEL_ENV_PREFIX="DRI_PRIME=pci-0000_03_00_0! VK_LOADER_DRIVERS_SELECT=*radeon* ..." \
#     bash scripts/model/start.sh qwen27b
#
# Minimal portable default. Put your full AMD prefix in config/models.local.env.
: "${MODEL_ENV_PREFIX:=RADV_PERFTEST=nogttspill}"

# Machine-specific overrides. This file is intentionally gitignored.
# Put your long AMD prefix, custom model paths, and larger startup timeout there.
MODELS_ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$MODELS_ENV_DIR/models.local.env" ]; then
  # shellcheck source=/dev/null
  source "$MODELS_ENV_DIR/models.local.env"
fi
unset MODELS_ENV_DIR
